{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "humand-eventos",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "humand-eventos-api",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "USE_MOCK_DATA=true npx vercel dev --token $(grep '^VERCEL_TOKEN=' .env.local | cut -d= -f2) --listen 3000"],
      "port": 3000
    }
  ]
}
