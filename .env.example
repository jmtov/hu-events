# Copy this file to .env.local and fill in the values.
# Never commit .env.local — it is ignored by git via *.local.

# -------------------------------------------------------------------------
# Mock data
# -------------------------------------------------------------------------
# Set to true to use local fixtures (api/_fixtures/) instead of Supabase.
# No Supabase credentials needed when this is true.
USE_MOCK_DATA=true

# -------------------------------------------------------------------------
# Supabase — required when USE_MOCK_DATA=false
# -------------------------------------------------------------------------
# Found in: Supabase dashboard → Project Settings → API
# Serverless functions only — never expose these to the browser
SUPABASE_URL=
# Use the service_role key (full access). Never expose to the frontend.
SUPABASE_SERVICE_KEY=

# -------------------------------------------------------------------------
# App URL — used to build the Google OAuth callback redirect URI
# -------------------------------------------------------------------------
# Local dev (Vercel dev): http://localhost:3000
# Production: https://your-app.vercel.app
APP_URL=http://localhost:3000

# -------------------------------------------------------------------------
# Claude API
# -------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -------------------------------------------------------------------------
# n8n webhooks
# -------------------------------------------------------------------------
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# -------------------------------------------------------------------------
# Google OAuth
# -------------------------------------------------------------------------
# Found in: Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -------------------------------------------------------------------------
# Session
# -------------------------------------------------------------------------
# Any long random string — used to sign session tokens.
# Generate one with: openssl rand -base64 32
SESSION_SECRET=
